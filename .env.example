# Copy to `.env` at the repo root and adjust for your machine.
# Loaded by: Docker Compose, Vite client, dev-stack.sh, and all Node services (root first, then local `.env`).

# --- PostgreSQL ---
# Set LOCAL_POSTGRES=1 to use Postgres on your Mac (e.g. Homebrew) and skip the postgres container in stack scripts.
# Leave unset or 0 to use Docker Compose postgres (default host port 5433).
# LOCAL_POSTGRES=1

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=roadmap_platform
# With Docker: host port published by compose (default 5433). With LOCAL_POSTGRES=1: usually 5432.
POSTGRES_PORT=5433

# One Postgres database, separate schemas so `prisma db push` in one service never drops another service’s tables.
# The `?schema=` parameter is required for each service. Port must match POSTGRES_PORT above.
PORTFOLIO_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/roadmap_platform?schema=portfolio
TEMPLATE_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/roadmap_platform?schema=template
INTEGRATION_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/roadmap_platform?schema=integration
AUTH_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/roadmap_platform?schema=auth

# Optional: alias for scripts/tools that still expect DATABASE_URL (portfolio schema only).
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/roadmap_platform?schema=portfolio

# Local Postgres (Homebrew): after copying this file, set LOCAL_POSTGRES=1, POSTGRES_PORT=5432, and replace :5433 with :5432
# in the four URLs above. One-time: ./scripts/setup-local-postgres.sh (creates role + DB). Then: npm run db:push:all

# --- Service URLs (gateway + cross-service HTTP) ---
PORTFOLIO_SERVICE_URL=http://localhost:4110
TEMPLATE_SERVICE_URL=http://localhost:4210
INTEGRATION_SERVICE_URL=http://localhost:4410
AI_SERVICE_URL=http://localhost:4310
AUTH_SERVICE_URL=http://localhost:4610

# Web client (`client/`): Vite dev server on port 3001 by default; browser calls `/api/*` same-origin and Vite proxies to the gateway (see `client/vite.config.js`). Override: `VITE_DEV_PORT=3000`.
# API_GATEWAY_INTERNAL_URL=http://127.0.0.1:4010
# API_GATEWAY_REWRITE_TARGET=http://127.0.0.1:4010

# Optional: direct gateway URL if you add a production build env for the SPA.
# VITE_API_BASE_URL=http://localhost:4010

# Client auth: set to `false` to require login for all app routes (pair with JWT_ENFORCE_GATEWAY=1 and running auth-service).
# When unset or true, the SPA allows browsing without a session (gateway may still allow anonymous API if JWT not enforced).
# VITE_AUTH_OPTIONAL=false

# Shared secret for internal routes (x-internal-key). If unset, internal routes are open — set in production.
# INTERNAL_API_KEY=your-random-secret

# Redis: import queue (BullMQ) + future cache. Worker and portfolio enqueue/consume.
REDIS_URL=redis://127.0.0.1:6379

# --- Optional ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OpenAI-compatible HTTP API (Ollama, LM Studio, etc.) — optional global default; workspace can override in Settings → AI.
# OPENAI_COMPATIBLE_BASE_URL=http://127.0.0.1:11434/v1
# Google Gemini (ai-service — used when workspace AI provider is Gemini or for env fallback)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Ports (defaults): postgres 5433 (host), gateway 4010, portfolio 4110, template 4210, ai 4310, integration 4410, worker 4510, auth 4610, client (Vite) 3001

# --- Authentication (CURSOR_AUTH_JWT_GUIDE.md) ---
# Same secret on gateway and auth-service; HS256 JWT, 7d expiry.
# JWT_SECRET=replace-with-long-random-string
# Set to 1 to require Bearer token on all /api/* except public auth routes (login, register, forgot/reset password).
# JWT_ENFORCE_GATEWAY=1
# First admin user (created once if email does not exist). Optional.
# AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@local.test
# AUTH_BOOTSTRAP_ADMIN_PASSWORD=changeme
# AUTH_BOOTSTRAP_ADMIN_NAME=Administrator
